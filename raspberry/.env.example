# MQTT broker
MQTT_HOST=192.168.0.10
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=
MQTT_QOS=1
MQTT_KEEPALIVE=60

# Map each MQTT topic (or wildcard) to a lote code.
# Example:
# {"tele/chacara/sala1/json":"LOT-2024-001","tele/chacara/sala2/json":"LOT-2024-002"}
MQTT_TOPIC_MAP_JSON={"tele/chacara/sala1/json":"LOT-2024-001"}

# Supabase ingest endpoint
INGEST_URL=https://zgxxbguoijamtbydcxrm.supabase.co/functions/v1/make-server-5522cecf/sensores/ingest
# Required in setups where Supabase Edge Functions enforce JWT.
# You can use SUPABASE_AUTH_TOKEN instead of SUPABASE_ANON_KEY if preferred.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InpneHhiZ3VvaWphbXRieWRjeHJtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjQ3OTgzMzEsImV4cCI6MjA4MDM3NDMzMX0.q2i_0EaHt3FyhIz5bjwnDM1T74ZtTT8LhsoRKyjFF1c
