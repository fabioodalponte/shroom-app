{
  "enabled": true,
  "site_name": "Shroom Bros",
  "environment": "development",
  "capture": {
    "camera_name": "camera-sala-1",
    "camera_url": "https://cam.cogumelos.net/capture",
    "request_timeout_seconds": 15,
    "request_retries": 3,
    "retry_backoff_seconds": 1.0,
    "verify_tls": true
  },
  "lighting": {
    "enabled": true,
    "warmup_seconds": 8,
    "cooldown_seconds": 1
  },
  "inference": {
    "enabled": true,
    "mode": "yolov8",
    "model": "vision/models/block_detector.pt",
    "device": "cpu",
    "confidence_threshold": 0.25,
    "target_labels": [
      "bloco",
      "colonizacao",
      "contaminacao_visual"
    ]
  },
  "quality": {
    "min_width": 640,
    "min_height": 480,
    "brightness": {
      "too_dark_below": 55.0,
      "too_bright_above": 210.0
    },
    "sharpness": {
      "too_blurry_below": 12.0
    }
  },
  "storage": {
    "artifacts_dir": "vision/storage/artifacts",
    "results_dir": "vision/storage/results",
    "dataset_dir": "vision/dataset",
    "reprocess_dir": "vision/storage/reprocess_queue"
  },
  "dataset_classification": {
    "enabled": true,
    "mode": "hardlink_or_copy",
    "valid_subdir": "raw/valid",
    "rejected_subdir": "raw/rejected"
  },
  "remote_persistence": {
    "enabled": true,
    "db_table": "vision_pipeline_runs",
    "storage_prefix": "vision/captures"
  },
  "logging": {
    "dir": "vision/logs",
    "file_name": "vision.log",
    "level": "INFO"
  }
}
